<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="mt-10 text-center text-2xl/9 font-bold tracking-tight text-gray-900"><%= t(".title") %></h2>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, t(".first_name"), class: "block text-sm/6 font-medium text-gray-900" %>
          <div class="mt-2">
            <%= f.text_field :first_name, required: true,
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          </div>
        </div>

        <div>
          <%= f.label :last_name, t(".last_name"), class: "block text-sm/6 font-medium text-gray-900" %>
          <div class="mt-2">
            <%= f.text_field :last_name, required: true,
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          </div>
        </div>
      </div>

      <div>
        <%= f.label :email, t(".email"), class: "block text-sm/6 font-medium text-gray-900" %>
        <div class="mt-2">
          <%= f.email_field :email, autocomplete: "email", required: true,
              class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
        </div>
      </div>

      <div>
        <%= f.label :gender, t(".gender"), class: "block text-sm/6 font-medium text-gray-900" %>
        <div class="mt-2 grid grid-cols-1">
          <%= f.select :gender, 
              options_for_select([
                [t(".gender_male"), "male"],
                [t(".gender_female"), "female"],
                [t(".gender_other"), "other"]
              ], resource.gender), 
              { prompt: t(".select_gender") }, 
              required: true,
              class: "col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-1.5 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          <svg class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end text-gray-500 sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
            <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </div>
      </div>

      <div>
        <%= f.label :lang, t(".language"), class: "block text-sm/6 font-medium text-gray-900" %>
        <div class="mt-2 grid grid-cols-1">
          <%= f.select :lang, 
              options_for_select([
                [t(".language_en"), "en"],
                [t(".language_de"), "de"]
              ], resource.lang), 
              { prompt: t(".select_language") }, 
              required: true,
              class: "col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-1.5 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          <svg class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end text-gray-500 sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
            <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </div>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="text-sm text-gray-500">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

      <div>
        <div class="flex items-center justify-between">
          <%= f.label :password, t(".password"), class: "block text-sm/6 font-medium text-gray-900" %>
          <span class="text-sm text-gray-500">(<%= t(".password_blank") %>)</span>
        </div>
        <div class="mt-2">
          <%= f.password_field :password, autocomplete: "new-password",
              class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          <% if @minimum_password_length %>
            <span class="text-sm text-gray-500">(<%= t(".password_minimum", count: @minimum_password_length) %>)</span>
          <% end %>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between">
          <%= f.label :current_password, t(".current_password"), class: "block text-sm/6 font-medium text-gray-900" %>
          <span class="text-sm text-gray-500">(<%= t(".current_password_needed") %>)</span>
        </div>
        <div class="mt-2">
          <%= f.password_field :current_password, autocomplete: "current-password", required: true,
              class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
        </div>
      </div>

      <div>
        <%= f.submit t(".submit"), class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
      </div>
    <% end %>

    <div class="mt-10 space-y-4">
      <div class="text-sm">
        <h3 class="font-medium text-gray-900"><%= t(".cancel_account") %></h3>
        <p class="mt-1 text-gray-500">
          <%= t(".unhappy") %>
          <%= button_to t(".cancel_account"), registration_path(resource_name), 
              data: { confirm: t(".cancel_confirm"), turbo_confirm: t(".cancel_confirm") }, 
              method: :delete, 
              class: "text-indigo-600 hover:text-indigo-500" %>
        </p>
      </div>

      <%= link_to t(".back"), :back, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>
</div>
