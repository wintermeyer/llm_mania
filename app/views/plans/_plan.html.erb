<div id="<%= dom_id plan %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Name:</strong>
    <%= plan.name %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Slug:</strong>
    <%= plan.slug %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Price:</strong>
    <%= plan.price %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Is active:</strong>
    <%= plan.is_active %>
  </p>
</div>
