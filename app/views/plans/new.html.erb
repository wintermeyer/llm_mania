<% content_for :title, "New Plan" %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-base font-semibold leading-6 text-gray-900">New Plan</h1>
      <p class="mt-2 text-sm text-gray-700">Create a new subscription plan.</p>
    </div>
  </div>

  <div class="mt-8">
    <%= render "form", plan: @plan %>
  </div>

  <div class="mt-6">
    <%= link_to "Back to plans", plans_path, class: "text-sm font-semibold leading-6 text-gray-900" %>
  </div>
</div>
